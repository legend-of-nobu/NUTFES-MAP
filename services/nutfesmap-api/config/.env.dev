# services/nutfesmap-api/config/.env.dev
# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=webapp
MYSQL_USER=webapp
MYSQL_PASSWORD=Password

# API DB接続
DB_USER=webapp
DB_PASSWORD=Password
DB_HOST=nutfesmap-database
DB_PORT=3306
DB_NAME=webapp

# API
APP_PORT=8080
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_HOUR=168
JWT_SIGNING_KEY=dev_change_me

# Cookie
COOKIE_DOMAIN=
COOKIE_PATH=/
COOKIE_SECURE=false
COOKIE_SAMESITE=None
COOKIE_NAME_RT=rt

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-CSRF-Token
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_CREDENTIALS=true

# CSRF
CSRF_COOKIE_NAME=XSRF-TOKEN
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_ENABLED=false

# Storage（必要なら調整）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=nutfes-assets
STORAGE_REGION=ap-northeast-1
STORAGE_USE_SSL=false
STORAGE_PUBLIC_BASEURL=http://localhost:9000/nutfes-assets
