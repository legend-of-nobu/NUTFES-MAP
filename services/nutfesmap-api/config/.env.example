# ---- MySQL official vars ----
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=webapp
MYSQL_USER=webapp
MYSQL_PASSWORD=Password

# ---- API用 DB接続情報 ----
DB_USER=webapp
DB_PASSWORD=Password
DB_HOST=nutfesmap-database
DB_PORT=3306
DB_NAME=webapp

# --- API ---
APP_PORT=8080
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_HOUR=168
JWT_SIGNING_KEY=change_me_now

# --- Cookie ---
COOKIE_DOMAIN=
COOKIE_PATH=/
COOKIE_SECURE=false
COOKIE_SAMESITE=None
COOKIE_NAME_RT=rt

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:9419
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-CSRF-Token
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_CREDENTIALS=true

# CSRF
CSRF_COOKIE_NAME=XSRF-TOKEN
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_ENABLED=false
